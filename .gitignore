# ════════════════════════════════════════════════════════════════════════════
# GeoPulse Intelligence — .gitignore
# ════════════════════════════════════════════════════════════════════════════

# ── Environment (CRITICAL — never commit real API keys) ───────────────────────
.env

# ── Python bytecode ───────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# ── Build & distribution ──────────────────────────────────────────────────────
*.egg-info/
*.egg
dist/
build/
.eggs/
wheels/
sdist/

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── uv ────────────────────────────────────────────────────────────────────────
# uv.lock is intentionally committed for reproducible uv installs
# .python-version is intentionally committed so uv knows which interpreter to use

# ── Node / Frontend ───────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.eslintcache


# ── Testing ───────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
*.xml        # junit test reports

# ── HuggingFace model cache (can be hundreds of MB) ──────────────────────────
.cache/
huggingface/
~/.cache/huggingface/

# ── spaCy model downloads (re-downloadable) ───────────────────────────────────
# (installed inside .venv, already ignored above)

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/
log/

# ── Data / database files ─────────────────────────────────────────────────────
# MongoDB data is local, no need to commit
data/
*.db
*.sqlite

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace
.project
.classpath

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini

# ── Jupyter (if used for research) ────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Temporary / scratch files ─────────────────────────────────────────────────
*.tmp
*.bak
*.orig
scratch/
tmp/
